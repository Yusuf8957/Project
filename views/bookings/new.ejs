<% layout("/layouts/boilerplate") %>

<style>
  .booking-card {
    border: none;
    border-radius: 1.5rem;
    box-shadow: 0 8px 32px rgba(254,66,77,0.12);
  }

  .form-control:focus {
    border-color: #fe424d;
    box-shadow: 0 0 0 0.2rem rgba(254,66,77,0.15);
  }

  .input-group-text {
    background: #fff0f0;
    border-color: #ffd0d3;
    color: #fe424d;
  }

  .price-summary {
    background: #fff8f8;
    border-radius: 1rem;
    padding: 1rem;
    border: 1px solid #ffd0d3;
  }

  body.dark-mode .booking-card { background: #1e1e1e; }
  body.dark-mode .price-summary { background: #2a1a1a; }
</style>

<div class="container d-flex justify-content-center align-items-center" style="min-height:85vh;">
  <div class="card p-4 booking-card" style="width:100%; max-width:520px;">

    <!-- Header -->
    <div class="text-center mb-4">
      <i class="fa-solid fa-calendar-check fa-2x mb-2" style="color:#fe424d;"></i>
      <h4 class="fw-bold mb-1">Book Your Stay</h4>
      <p class="text-muted small"><%= listing.title %> — <%= listing.location %></p>
    </div>

    <!-- Flash -->
    <% if(error && error.length > 0){ %>
      <div class="alert alert-danger rounded-3 small"><%= error %></div>
    <% } %>

    <form action="/bookings/<%= listing._id %>/book" method="POST" id="bookingForm">

      <!-- Check-in -->
      <div class="mb-3">
        <label class="form-label fw-semibold">Check-in Date</label>
        <div class="input-group">
          <span class="input-group-text">
            <i class="fa-solid fa-calendar-days"></i>
          </span>
          <input
            type="date"
            name="checkIn"
            id="checkIn"
            class="form-control"
            required
            min="<%= new Date().toISOString().split('T')[0] %>"
          />
        </div>
      </div>

      <!-- Check-out -->
      <div class="mb-4">
        <label class="form-label fw-semibold">Check-out Date</label>
        <div class="input-group">
          <span class="input-group-text">
            <i class="fa-solid fa-calendar-days"></i>
          </span>
          <input
            type="date"
            name="checkOut"
            id="checkOut"
            class="form-control"
            required
            min="<%= new Date().toISOString().split('T')[0] %>"
          />
        </div>
      </div>

      <!-- Price Summary -->
      <div class="price-summary mb-4" id="priceSummary" style="display:none;">
        <div class="d-flex justify-content-between mb-2">
          <span class="text-muted">Price per night</span>
          <span class="fw-bold">₹<%= listing.price.toLocaleString("en-IN") %></span>
        </div>
        <div class="d-flex justify-content-between mb-2">
          <span class="text-muted">Number of nights</span>
          <span class="fw-bold" id="numNights">0</span>
        </div>
        <hr style="border-color:#ffd0d3;">
        <div class="d-flex justify-content-between">
          <span class="fw-bold" style="color:#fe424d;">Total Amount</span>
          <span class="fw-bold fs-5" style="color:#fe424d;" id="totalAmount">₹0</span>
        </div>
      </div>

      <!-- Proceed to Payment Button -->
      <button
        type="submit"
        id="proceedBtn"
        class="btn w-100 py-2 fw-bold"
        style="background:linear-gradient(135deg,#fe424d,#ff6b6b); color:white; border-radius:50px; border:none; opacity:0.6; cursor:not-allowed;"
        disabled
      >
        <i class="fa-solid fa-indian-rupee-sign me-2"></i>
        Proceed to Payment
      </button>

    </form>

    <!-- Back -->
    <div class="text-center mt-3">
      <a href="/listings/<%= listing._id %>" class="text-muted small">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Listing
      </a>
    </div>

  </div>
</div>

<script>
  const pricePerNight = <%= listing.price %>;
  const checkInInput = document.getElementById("checkIn");
  const checkOutInput = document.getElementById("checkOut");
  const priceSummary = document.getElementById("priceSummary");
  const numNightsEl = document.getElementById("numNights");
  const totalAmountEl = document.getElementById("totalAmount");
  const proceedBtn = document.getElementById("proceedBtn");

  function calculatePrice() {
    const checkIn = new Date(checkInInput.value);
    const checkOut = new Date(checkOutInput.value);

    if (checkInInput.value && checkOutInput.value && checkOut > checkIn) {
      const nights = Math.ceil((checkOut - checkIn) / (1000 * 60 * 60 * 24));
      const total = nights * pricePerNight;

      numNightsEl.textContent = nights;
      totalAmountEl.textContent = "₹" + total.toLocaleString("en-IN");
      priceSummary.style.display = "block";

      // Enable button
      proceedBtn.disabled = false;
      proceedBtn.style.opacity = "1";
      proceedBtn.style.cursor = "pointer";
      proceedBtn.innerHTML = `<i class="fa-solid fa-indian-rupee-sign me-2"></i> Pay ₹${total.toLocaleString("en-IN")}`;

    } else {
      priceSummary.style.display = "none";
      proceedBtn.disabled = true;
      proceedBtn.style.opacity = "0.6";
      proceedBtn.style.cursor = "not-allowed";
      proceedBtn.innerHTML = `<i class="fa-solid fa-indian-rupee-sign me-2"></i> Proceed to Payment`;
    }

    // Check-out min date
    if (checkInInput.value) {
      const nextDay = new Date(checkIn);
      nextDay.setDate(nextDay.getDate() + 1);
      checkOutInput.min = nextDay.toISOString().split("T")[0];
    }
  }

  checkInInput.addEventListener("change", calculatePrice);
  checkOutInput.addEventListener("change", calculatePrice);
</script>
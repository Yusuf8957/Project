<style>
/* 🔥 CENTER SEARCH BAR */
.search-wrapper {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

/* SEARCH STYLE */
.search-wrapper form {
  display: flex;
  gap: 12px;
  align-items: center;
}

.search-wrapper .form-control {
  border-radius: 50px;
  border: 1px solid #ddd;
  padding: 8px 16px;
  width: 260px;
}

.btn-search {
  background-color: #fe424d;
  color: #fff;
  border-radius: 50px;
  padding: 8px 18px;
  border: none;
  display: flex;
  align-items: center;
  gap: 6px;
}
</style>

<nav class="navbar navbar-expand-md bg-body-tertiary border-bottom sticky-top position-relative">
  <div class="container-fluid">

    <!-- 🔥 LEFT SIDE -->
    <div class="d-flex align-items-center gap-3">
      <a class="navbar-brand" href="/listings">
        <i class="fa-regular fa-compass"></i>
      </a>

      <a class="nav-link" href="/listings">Explore</a>
    </div>

    <!-- TOGGLE -->
    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- 🔥 CENTER SEARCH -->
    <div class="search-wrapper">
      <form role="search">
        <input class="form-control" type="search" placeholder="Search destinations"/>
        <button class="btn btn-search" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>
          Search
        </button>
      </form>
    </div>

    <!-- 🔥 RIGHT SIDE -->
    <div class="collapse navbar-collapse justify-content-end" id="navbarNavAltMarkup">
      <div class="navbar-nav">

        <a class="nav-link" href="/listings/new">Airbnb your home</a>

        <% if(!currUser){ %>
          <a class="nav-link" href="/signup"><b>Sign up</b></a>
          <a class="nav-link" href="/login"><b>Log in</b></a>
        <% } %>

        <% if(currUser){ %>
          <a class="nav-link" href="/logout"><b>Log out</b></a>
        <% } %>

<button id="darkModeToggle" class="nav-link border-0 bg-transparent">
  <i class="fa-solid fa-moon"></i>
</button>

      </div>
    </div>

  </div>
</nav>
<% layout("/layouts/boilerplate") %>

<style>
  .show-hero {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.15);
  }

  .show-hero img {
    width: 100%;
    height: 50vh;
    object-fit: cover;
  }

  .show-hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    padding: 2rem;
    color: white;
  }

  .show-details-card {
    border: none;
    border-radius: 1.5rem;
    box-shadow: 0 8px 32px rgba(254,66,77,0.10);
    padding: 1.5rem;
    background: white;
  }

  body.dark-mode .show-details-card {
    background: #1e1e1e;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  .owner-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff0f0;
    border-radius: 50px;
    padding: 6px 16px;
    font-size: 0.9rem;
    color: #fe424d;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  body.dark-mode .owner-badge {
    background: #2a1a1a;
  }

  .price-tag {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fe424d;
  }

  .btn-book-now {
    background: linear-gradient(135deg, #fe424d, #ff6b6b);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 12px 30px;
    font-weight: 700;
    font-size: 1rem;
    width: 100%;
    box-shadow: 0 6px 20px rgba(254,66,77,0.35);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    display: block;
    text-align: center;
  }

  .btn-book-now:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(254,66,77,0.45);
    color: white;
  }

  .review-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    margin-bottom: 1rem;
    padding: 1rem;
    transition: transform 0.2s;
  }

  .review-card:hover {
    transform: translateY(-3px);
  }

  body.dark-mode .review-card {
    background: #1e1e1e;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }

  .review-form-card {
    border: none;
    border-radius: 1.5rem;
    box-shadow: 0 6px 24px rgba(254,66,77,0.08);
    padding: 1.5rem;
    background: white;
    margin-bottom: 2rem;
  }

  body.dark-mode .review-form-card {
    background: #1e1e1e;
  }

  .section-title {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 1.2rem;
    position: relative;
    padding-bottom: 0.5rem;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background: linear-gradient(135deg, #fe424d, #ff6b6b);
    border-radius: 50px;
  }

  .edit-delete-btns {
    display: flex;
    gap: 0.5rem;
    margin: 1rem 0;
  }

  .btn-edit {
    background: #222;
    color: white;
    border: none;
    border-radius: 50px;
    padding: 8px 24px;
    font-weight: 600;
    transition: transform 0.2s;
  }

  .btn-edit:hover {
    transform: translateY(-2px);
    color: white;
    background: #444;
  }

  .btn-delete {
    background: white;
    color: #fe424d;
    border: 2px solid #fe424d;
    border-radius: 50px;
    padding: 8px 24px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-delete:hover {
    background: #fe424d;
    color: white;
    transform: translateY(-2px);
  }

  body.dark-mode .btn-delete {
    background: transparent;
  }
</style>

<div class="mt-4 mb-5">

  <!-- HERO IMAGE -->
  <div class="show-hero mb-4">
    <img
      src="<%= listing.image.url.startsWith('http')
        ? listing.image.url
        : (listing.image.url.startsWith('/')
            ? listing.image.url
            : '/' + listing.image.url) %>"
      alt="<%= listing.title %>"
      onerror="this.src='https://via.placeholder.com/800x400'"
    />
    <div class="show-hero-overlay">
      <h2 class="fw-bold mb-1"><%= listing.title %></h2>
      <p class="mb-0 opacity-75">
        <i class="fa-solid fa-location-dot me-1"></i>
        <%= listing.location %>, <%= listing.country %>
      </p>
    </div>
  </div>

  <div class="row g-4">

    <!-- LEFT — DETAILS -->
    <div class="col-12 col-md-7">
      <div class="show-details-card">

        <!-- Owner -->
        <div class="owner-badge">
          <i class="fa-solid fa-user-circle"></i>
          Hosted by <%= listing.owner ? listing.owner.username : "Anonymous" %>
        </div>

        <!-- Description -->
        <p class="text-muted mb-3"><%= listing.description %></p>

        <!-- Price -->
        <div class="d-flex align-items-center gap-2 mb-3">
          <span class="price-tag">₹<%= listing.price.toLocaleString("en-IN") %></span>
          <span class="text-muted">/ night</span>
        </div>

        <!-- Location -->
        <p class="mb-3">
          <i class="fa-solid fa-map-pin" style="color:#fe424d;"></i>
          <strong><%= listing.location %>, <%= listing.country %></strong>
        </p>

       

  <!-- ✅ ALWAYS SHOW BOOK BUTTON -->
  <% if(currUser){ %>

  <!-- ✅ Book Now -->
  <a href="/bookings/<%= listing._id %>/book" class="btn-book-now">
    <i class="fa-solid fa-calendar-check me-2"></i> Book Now
  </a>

  <!-- OPTIONAL: owner message -->
  <% if(listing.owner && listing.owner._id.equals(currUser._id)){ %>
    <div class="alert alert-warning mt-2 text-center">
      You are booking your own listing
    </div>
  <% } %>

<% } else { %>

  <!-- Login button -->
  <a href="/login" class="btn-book-now">
    <i class="fa-solid fa-lock me-2"></i> Login to Book
  </a>

<% } %>

        <!-- EDIT / DELETE -->
        <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)){ %>
          <div class="edit-delete-btns mt-3">
            <a href="/listings/<%= listing._id %>/edit" class="btn-edit">
              <i class="fa-solid fa-pen"></i> Edit
            </a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
              <button class="btn-delete">
                <i class="fa-solid fa-trash"></i> Delete
              </button>
            </form>
          </div>
        <% } %>

      </div>
    </div>

    <!-- RIGHT — MAP -->
    <div class="col-12 col-md-5">
      <div class="show-details-card">
        <h5 class="section-title">📍 Location</h5>
        <div id="map" style="height:300px; border-radius:1rem;"></div>
      </div>
    </div>

  </div>

  <!-- REVIEW FORM -->
  <div class="review-form-card mt-4">
    <h5 class="section-title">✍️ Leave a Review</h5>

    <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
      <fieldset class="starability-slot mb-3">
        <legend class="fw-bold mb-2">Rating:</legend>
        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked />
        <input type="radio" id="rate1" name="review[rating]" value="1" />
        <label for="rate1">1 star</label>
        <input type="radio" id="rate2" name="review[rating]" value="2" />
        <label for="rate2">2 stars</label>
        <input type="radio" id="rate3" name="review[rating]" value="3" />
        <label for="rate3">3 stars</label>
        <input type="radio" id="rate4" name="review[rating]" value="4" />
        <label for="rate4">4 stars</label>
        <input type="radio" id="rate5" name="review[rating]" value="5" />
        <label for="rate5">5 stars</label>
      </fieldset>

      <div class="mb-3">
        <label class="form-label fw-bold">Your Comment</label>
        <textarea
          name="review[comment]"
          class="form-control"
          rows="3"
          placeholder="Share your experience..."
          required
        ></textarea>
        <div class="invalid-feedback">Please add a comment</div>
      </div>

      <% if(currUser){ %>
        <button type="submit" class="btn-book-now" style="background:linear-gradient(135deg,#222,#444); box-shadow:none;">
          <i class="fa-solid fa-paper-plane me-2"></i> Submit Review
        </button>
      <% } else { %>
        <a href="/login?redirect=/listings/<%= listing._id %>"
          class="btn-book-now" style="background:linear-gradient(135deg,#222,#444); box-shadow:none;">
          <i class="fa-solid fa-lock me-2"></i> Login to Review
        </a>
      <% } %>
    </form>
  </div>

  <!-- ALL REVIEWS -->
  <% if(listing.reviews.length > 0){ %>
    <h5 class="section-title mt-2">⭐ All Reviews (<%= listing.reviews.length %>)</h5>
    <div class="row g-3">
      <% for(let review of listing.reviews){ %>
        <div class="col-12 col-md-6">
          <div class="review-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div>
                <h6 class="fw-bold mb-0">
                  <i class="fa-solid fa-user-circle" style="color:#fe424d;"></i>
                  @<%= review.author ? review.author.username : "User" %>
                </h6>
              </div>
              <% if(currUser && review.author && review.author._id.equals(currUser._id)){ %>
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-sm" style="background:none; border:none; color:#fe424d;">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              <% } %>
            </div>
            <p class="starability-result mb-1" data-rating="<%= review.rating %>"></p>
            <p class="card-text text-muted small"><%= review.comment %></p>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

</div>

<script src="/js/map.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const coords = <%- listing.geometry && listing.geometry.coordinates
      ? JSON.stringify(listing.geometry.coordinates)
      : JSON.stringify([77.23, 28.61]) %>;
    const title = "<%= listing.title %>";
    const price = "<%= listing.price %>";
    if (typeof initMap === "function") {
      initMap(coords, title, price);
    }
  });
</script>
<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>
  </div>

  <div class="card col-6 offset-3 show-card listing-card">

    <img 
      src="<%= listing.image.url.startsWith('http') 
        ? listing.image.url 
        : (listing.image.url.startsWith('/') 
            ? listing.image.url 
            : '/' + listing.image.url) %>" 
      class="card-img-top show-img" 
      alt="listing_image"
      onerror="this.src='https://via.placeholder.com/400'"
    />

    <div class="card-body">
      <p class="card-text">
        Owned by <%= listing.owner ? listing.owner.username : "Anonymous" %>
      </p>

      <p><%= listing.description %></p>
      <p>&#8377; <%= listing.price.toLocaleString("en-IN") %></p>
      <p><%= listing.location %>, <%= listing.country %></p>
    </div>
  </div>

  <br/>
</div>

<!-- EDIT / DELETE -->
<% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)){ %>
<div class="btns">
  <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">
    Edit
  </a>

  <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
    <button class="btn btn-dark offset-5">Delete</button>
  </form>
</div>
<% } %>

<div class="col-8 offset-3 mb-3">
  <hr>

  <!-- ✅ Review form sabko dikhega -->
  <h4>Leave a Review</h4>

  <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">

    <fieldset class="starability-slot">
      <legend>Rating:</legend>

      <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked />

      <input type="radio" id="rate1" name="review[rating]" value="1" />
      <label for="rate1">1 star</label>

      <input type="radio" id="rate2" name="review[rating]" value="2" />
      <label for="rate2">2 stars</label>

      <input type="radio" id="rate3" name="review[rating]" value="3" />
      <label for="rate3">3 stars</label>

      <input type="radio" id="rate4" name="review[rating]" value="4" />
      <label for="rate4">4 stars</label>

      <input type="radio" id="rate5" name="review[rating]" value="5" />
      <label for="rate5">5 stars</label>
    </fieldset>

    <div class="mb-3 mt-3">
      <label class="form-label">Comments</label>
      <textarea name="review[comment]" class="form-control" required></textarea>
      <div class="invalid-feedback">Please add a comment</div>
    </div>

    <!-- ✅ Logged in → real submit, Logged out → redirect to login -->
<% if(currUser){ %>
  <button type="submit" class="btn btn-outline-dark">Submit</button>
<% } else { %>
  <!-- ✅ Flash manually set karenge via redirect -->
  <a 
    href="/login?redirect=/listings/<%= listing._id %>&message=Please+login+first+to+leave+a+review!" 
    class="btn btn-outline-dark"
  >
    Submit
  </a>
<% } %>

  </form>

  <hr/>

  <p><b>All Reviews</b></p>

  <div class="row">
    <% for(let review of listing.reviews){ %>
      <div class="card col-5 ms-3 mb-3"> 
        <div class="card-body">

          <h5 class="card-title">
            @<%= review.author ? review.author.username : "User" %>
          </h5>

          <p class="starability-result" data-rating="<%= review.rating %>"></p>

          <p class="card-text"><%= review.comment %></p>

          <p>Rated: <%= review.rating %> stars</p>
        </div>

        <!-- DELETE — sirf author ko dikhega -->
        <% if(currUser && review.author && review.author._id.equals(currUser._id)){ %>
        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
          <button class="btn btn-sm btn-dark">Delete</button>
        </form>
        <% } %>

      </div>
    <% } %>
  </div>
</div>

<!-- MAP SECTION -->
<div class="col-8 offset-3 mt-3">
  <h4>Location</h4>
  <div id="map" style="height:400px; border-radius:12px;"></div>
</div>

<!-- MAP SCRIPT -->
<script src="/js/map.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const coords = <%- listing.geometry && listing.geometry.coordinates
      ? JSON.stringify(listing.geometry.coordinates)
      : JSON.stringify([77.23, 28.61]) %>;

    const title = "<%= listing.title %>";
    const price = "<%= listing.price %>";

    if (typeof initMap === "function") {
      initMap(coords, title, price);
    } else {
      console.log("initMap not found ❌");
    }
  });
</script>
<% layout("layouts/boilerplate") %>

<div class="container d-flex justify-content-center align-items-center" style="min-height:70vh;">
  <div class="card p-4 shadow" style="width:100%; max-width:420px; border-radius:1.5rem; border:none;">

    <div class="text-center mb-4">
      <i class="fa-solid fa-shield-halved fa-3x mb-3" style="color:#fe424d;"></i>
      <h4 class="fw-bold">Enter OTP</h4>
      <p class="text-muted small">
        OTP has been sent to: <strong><%= identifier %></strong>
      </p>
      <p class="text-muted" style="font-size:0.78rem;">
        ⏱ OTP is valid for <strong>1 minute</strong>
      </p>
    </div>

    <!-- Flash errors -->
    <% if(error && error.length > 0){ %>
      <div class="alert alert-danger rounded-3"><%= error %></div>
    <% } %>

    <!-- Form action: forgot password OTP alag route pe jayega -->
    <% if(type === "forgot"){ %>
      <form action="/verify-forgot-otp" method="POST">
    <% } else { %>
      <form action="/verify-otp" method="POST">
    <% } %>

      <!-- isSignup flag -->
      <input type="hidden" name="isSignup" value="<%= typeof isSignup !== 'undefined' && isSignup ? 'true' : 'false' %>">

      <div class="mb-3">
        <input
          type="text"
          name="otp"
          maxlength="6"
          placeholder="Enter 6-digit OTP"
          class="form-control form-control-lg text-center fw-bold"
          style="letter-spacing:8px; border-radius:1rem; border:2px solid #fe424d; font-size:1.5rem;"
          required
          autofocus
        />
      </div>

      <button type="submit" class="btn w-100 py-2 fw-bold"
        style="background:linear-gradient(135deg,#fe424d,#ff6b6b); color:white; border-radius:50px;">
        Verify OTP ✅
      </button>

    </form>

    <!-- Resend OTP — signup ke liye nahi, sirf forgot/login ke liye -->
    <% if(type === "forgot"){ %>
      <form action="/forgot-password" method="POST" class="mt-3 text-center">
        <input type="hidden" name="email" value="<%= identifier %>">
        <button type="submit" class="btn btn-link text-muted small p-0">
          Didn't receive OTP? Resend
        </button>
      </form>
    <% } %>

    <div class="text-center mt-2">
      <% if(typeof isSignup !== 'undefined' && isSignup){ %>
        <a href="/signup" class="text-muted small">← Back to Signup</a>
      <% } else { %>
        <a href="/login" class="text-muted small">← Back to Login</a>
      <% } %>
    </div>

  </div>
</div>
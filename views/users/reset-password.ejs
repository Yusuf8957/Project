<% layout("layouts/boilerplate") %>

<div class="container d-flex justify-content-center align-items-center" style="min-height:70vh;">
  <div class="card p-4 shadow" style="width:100%; max-width:420px; border-radius:1.5rem; border:none;">

    <div class="text-center mb-4">
      <i class="fa-solid fa-key fa-3x mb-3" style="color:#fe424d;"></i>
      <h4 class="fw-bold">Reset Password</h4>
      <p class="text-muted small">Enter your new password below</p>
    </div>

    <% if(locals.error && error.length > 0){ %>
      <div class="alert alert-danger rounded-3"><%= error %></div>
    <% } %>

    <form action="/reset-password" method="POST">
      <input type="hidden" name="email" value="<%= email %>">

      <div class="mb-3">
        <label for="newPassword" class="form-label">New Password</label>
        <input
          type="password"
          name="newPassword"
          id="newPassword"
          class="form-control"
          placeholder="Enter new password"
          required
          autofocus
        />
      </div>

      <div class="mb-3">
        <label for="confirmPassword" class="form-label">Confirm Password</label>
        <input
          type="password"
          name="confirmPassword"
          id="confirmPassword"
          class="form-control"
          placeholder="Confirm new password"
          required
        />
      </div>

      <button type="submit" class="btn w-100 py-2 fw-bold"
        style="background:linear-gradient(135deg,#fe424d,#ff6b6b); color:white; border-radius:50px;">
        Reset Password
      </button>
    </form>

  </div>
</div>